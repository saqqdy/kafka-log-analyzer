# Kafka Log Analyzer Configuration

# Prometheus (Phase 2)
PROMETHEUS_URL=http://localhost:9090
PROMETHEUS_TIMEOUT=30000

# Kafka Exporter (Phase 2)
KAFKA_EXPORTER_URL=http://localhost:9308

# Loki (Phase 2)
LOKI_URL=http://localhost:3100

# Grafana Webhook (Phase 3)
GRAFANA_WEBHOOK_PORT=3100

# Integrations (Phase 3)
FEISHU_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
JIRA_URL=
JIRA_TOKEN=

# Storage
SQLITE_PATH=./storage/kafka-analyzer.db

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
